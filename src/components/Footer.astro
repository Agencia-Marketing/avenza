---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import { site } from '../config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = `/${lang}`;

const pages = [
  { href: `${base}/`, label: t('nav_home') },
  { href: `${base}/nosotros`, label: t('nav_about') },
  { href: `${base}/servicios`, label: t('nav_services') },
  { href: `${base}/recursos`, label: t('nav_resources') },
  { href: `${base}/contacto`, label: t('nav_contact') },
];
const services = [
  t('footer_srv1'), t('footer_srv2'), t('footer_srv3'),
  t('footer_srv4'), t('footer_srv5'), t('footer_srv6'),
];
---
<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <img src="/logo-white.svg" alt="Avenza Financial Consulting" width="180" height="39" />
      <p>{t('footer_brand_p')}</p>
      <div class="footer-social">
        <a href={site.social.facebook} aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href={site.social.instagram} aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href={site.social.tiktok} aria-label="TikTok" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24"><path d="M15 3v10.5a3.5 3.5 0 1 1-3.5-3.5"></path><path d="M15 3a5 5 0 0 0 5 5"></path></svg>
        </a>
        <a href={`https://wa.me/${site.whatsapp}`} aria-label="WhatsApp" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        </a>
      </div>
    </div>
    <div class="footer-col">
      <h4>{t('footer_pages_h')}</h4>
      <ul>
        {pages.map((p) => (<li><a href={p.href}>{p.label}</a></li>))}
      </ul>
    </div>
    <div class="footer-col">
      <h4>{t('footer_srv_h')}</h4>
      <ul>
        {services.map((s) => (<li><a href={`${base}/servicios`}>{s}</a></li>))}
      </ul>
    </div>
    <div class="footer-col">
      <h4>{t('footer_contact_h')}</h4>
      <div class="footer-contact-item">
        <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        <a href={`mailto:${site.email}`} style="color:inherit;text-decoration:none">{site.email}</a>
      </div>
      <div class="footer-contact-item">
        <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        {site.phone}
      </div>
      <div class="footer-contact-item">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        {t('footer_online')}
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>{t('footer_copy')}</span>
    <span>{t('footer_credit')}</span>
  </div>
</footer>
