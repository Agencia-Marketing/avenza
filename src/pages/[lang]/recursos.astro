---
import Base from '../../layouts/Base.astro';
import CalendlyButton from '../../components/CalendlyButton.astro';
import { getCollection } from 'astro:content';
import { langStaticPaths } from '../../i18n/paths';
import { useTranslations, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return langStaticPaths();
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const base = `/${lang}`;

const isProd = import.meta.env.PROD;
const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === lang && (!isProd || !p.data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const dateFmt = new Intl.DateTimeFormat(lang, { year: 'numeric', month: 'long', day: 'numeric' });
const slugOf = (id: string) => id.split('/').pop()!;
---
<Base lang={lang} title={`${t('rec_h1')} | Avenza`} description={t('rec_hero_p')}>
  <section class="hero-sub">
    <div class="container">
      <p class="section-tag" style="color:rgba(255,255,255,0.6)">{t('rec_tag')}</p>
      <h1>{t('rec_h1')}</h1>
      <div class="divider-line"></div>
      <p>{t('rec_hero_p')}</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header">
        <p class="section-tag">{t('rec_content_tag')}</p>
        <h2 class="section-title">{t('rec_content_h')}</h2>
        <div class="divider-line left"></div>
        <p class="section-subtitle">{t('rec_content_p')}</p>
      </div>
      {posts.length === 0 ? (
        <div class="blog-empty">{t('rec_empty')}</div>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <a class="blog-card" href={`${base}/recursos/${slugOf(post.id)}`}>
              {post.data.cover && <img class="cover" src={post.data.cover} alt="" loading="lazy" />}
              <div class="body">
                <span class="date">{dateFmt.format(post.data.pubDate)}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.map((tag) => (<span class="blog-tag">{tag}</span>))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
      <div class="resources-cta-box">
        <h3>{t('rec_cta_h')}</h3>
        <p>{t('rec_cta_p')}</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center">
          <CalendlyButton label={t('rec_cta_btn')} variant="navy" />
        </div>
      </div>
    </div>
  </section>
</Base>
