---
import Base from '../../layouts/Base.astro';
import CalendlyButton from '../../components/CalendlyButton.astro';
import { langStaticPaths } from '../../i18n/paths';
import { useTranslations, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return langStaticPaths();
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const base = `/${lang}`;

const topics = [
  { n: 1, icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline>' },
  { n: 2, icon: '<rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>' },
  { n: 3, icon: '<line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>' },
  { n: 4, icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle>' },
  { n: 5, icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>' },
  { n: 6, icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>' },
  { n: 7, icon: '<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>' },
];
---
<Base lang={lang} title={`${t('rec_h1')} | Avenza`} description={t('rec_hero_p')}>
  <section class="hero-sub">
    <div class="container">
      <p class="section-tag" style="color:rgba(255,255,255,0.6)">{t('rec_tag')}</p>
      <h1>{t('rec_h1')}</h1>
      <div class="divider-line"></div>
      <p>{t('rec_hero_p')}</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header">
        <p class="section-tag">{t('rec_content_tag')}</p>
        <h2 class="section-title">{t('rec_content_h')}</h2>
        <div class="divider-line left"></div>
        <p class="section-subtitle">{t('rec_content_p')}</p>
      </div>
      <div class="resources-topics">
        {topics.map((topic) => (
          <div class="resource-topic">
            <div class="rt-icon"><svg viewBox="0 0 24 24" set:html={topic.icon}></svg></div>
            <h3>{t(`rt${topic.n}_h` as any)}</h3>
            <p>{t(`rt${topic.n}_p` as any)}</p>
          </div>
        ))}
      </div>
      <div class="resources-cta-box">
        <h3>{t('rec_cta_h')}</h3>
        <p>{t('rec_cta_p')}</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center">
          <a href={`${base}/blog`} class="btn-navy">Blog →</a>
          <CalendlyButton label={t('rec_cta_btn')} variant="navy" />
        </div>
      </div>
    </div>
  </section>
</Base>
