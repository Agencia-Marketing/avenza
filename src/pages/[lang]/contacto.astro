---
import Base from '../../layouts/Base.astro';
import CalendlyButton from '../../components/CalendlyButton.astro';
import { langStaticPaths } from '../../i18n/paths';
import { useTranslations, type Lang } from '../../i18n/ui';
import { site } from '../../config';

export function getStaticPaths() {
  return langStaticPaths();
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const serviceOpts = ['form_opt1','form_opt2','form_opt3','form_opt4','form_opt5','form_opt6','form_opt7'] as const;
---
<Base lang={lang} title={`${t('con_h1')} | Avenza`} description={t('con_hero_p')}>
  <section class="hero-sub">
    <div class="container">
      <p class="section-tag" style="color:rgba(255,255,255,0.6)">{t('con_tag')}</p>
      <h1>{t('con_h1')}</h1>
      <div class="divider-line"></div>
      <p>{t('con_hero_p')}</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="contact-grid" style="margin-bottom:2rem">
        <div>
          <h2 class="section-title" style="font-size:1.5rem">{t('con_h2')}</h2>
          <p style="color:var(--gray-600);line-height:1.75;margin-bottom:1.5rem">{t('con_p')}</p>
          <div class="contact-item">
            <div class="ci-icon"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg></div>
            <div class="ci-text"><div class="lbl">{t('con_lbl_email')}</div><div class="val"><a href={`mailto:${site.email}`} style="color:inherit;text-decoration:none">{site.email}</a></div></div>
          </div>
          <div class="contact-item">
            <div class="ci-icon"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg></div>
            <div class="ci-text"><div class="lbl">{t('con_lbl_wa')}</div><div class="val"><a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener" style="color:inherit;text-decoration:none">{site.phone}</a></div></div>
          </div>
          <div class="contact-item">
            <div class="ci-icon"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></div>
            <div class="ci-text"><div class="lbl">{t('con_lbl_fb')}</div><div class="val">{site.facebookName}</div></div>
          </div>
          <div class="contact-item">
            <div class="ci-icon"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></div>
            <div class="ci-text"><div class="lbl">{t('con_lbl_ig')}</div><div class="val">{site.instagramHandle}</div></div>
          </div>
        </div>

        <div class="form-card">
          <h3>{t('form_h3')}</h3>
          <p>{t('form_p')}</p>
          <div id="form-status" class="form-status" role="status" aria-live="polite"></div>
          <form id="contact-form" method="POST" action="/api/contact">
            <input type="hidden" name="lang" value={lang} />
            <!-- Honeypot: real users never fill this -->
            <div class="hp-field" aria-hidden="true">
              <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="cf-name">{t('form_lbl_name')}</label>
                <input id="cf-name" name="name" type="text" required placeholder={t('form_ph_name')} />
              </div>
              <div class="form-group">
                <label for="cf-email">{t('form_lbl_email')}</label>
                <input id="cf-email" name="email" type="email" required placeholder={t('form_ph_email')} />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="cf-service">{t('form_lbl_srv')}</label>
                <select id="cf-service" name="service">
                  <option value="">{t('form_ph_srv')}</option>
                  {serviceOpts.map((o) => (<option value={t(o)}>{t(o)}</option>))}
                </select>
              </div>
              <div class="form-group">
                <label for="cf-type">{t('form_lbl_type')}</label>
                <select id="cf-type" name="type">
                  <option value="">{t('form_ph_type')}</option>
                  <option value={t('form_opt_personal')}>{t('form_opt_personal')}</option>
                  <option value={t('form_opt_biz')}>{t('form_opt_biz')}</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="cf-message">{t('form_lbl_msg')}</label>
              <textarea id="cf-message" name="message" required placeholder={t('form_ph_msg')}></textarea>
            </div>
            <button type="submit" class="btn-submit" id="cf-submit">{t('form_submit')}</button>
            <p style="font-size:.78rem;color:var(--gray-400);text-align:center;margin-top:1rem">{t('form_footer_txt')}</p>
          </form>
        </div>
      </div>

      <div class="contact-grid">
        <div class="online-info">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          <p set:html={t('con_online_p')}></p>
        </div>
        <div style="background:var(--ocre);border-radius:var(--radius-lg);padding:2rem;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;gap:1.25rem;height:100%">
          <div>
            <p style="font-size:.75rem;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:.1em;font-weight:700;margin-bottom:.4rem">{lang === 'es' ? '¿Prefieres agendar directo?' : 'Prefer to book directly?'}</p>
            <p style="color:#fff;font-weight:600;font-size:1.1rem;margin:0;line-height:1.4">{lang === 'es' ? 'Reserva tu consulta online en minutos' : 'Book your online consultation in minutes'}</p>
          </div>
          <CalendlyButton
            label={`${lang === 'es' ? 'Agendar cita' : 'Book appointment'} →`}
            variant="primary"
            style="background:#fff;color:var(--ocre);font-weight:700;"
          />
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ okMsg: lang === 'es' ? '¡Mensaje enviado! Te responderemos pronto.' : 'Message sent! We\'ll get back to you soon.', errMsg: lang === 'es' ? 'No se pudo enviar. Intenta de nuevo o escríbenos por email.' : 'Could not send. Please try again or email us.', sending: lang === 'es' ? 'Enviando…' : 'Sending…', submitLabel: t('form_submit') }}>
    const form = document.getElementById('contact-form');
    const statusEl = document.getElementById('form-status');
    const submitBtn = document.getElementById('cf-submit');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusEl.className = 'form-status';
      submitBtn.disabled = true;
      submitBtn.textContent = sending;
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          statusEl.textContent = okMsg;
          statusEl.className = 'form-status show ok';
          form.reset();
        } else {
          statusEl.textContent = data.error || errMsg;
          statusEl.className = 'form-status show err';
        }
      } catch (_) {
        statusEl.textContent = errMsg;
        statusEl.className = 'form-status show err';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    });
  </script>
</Base>
