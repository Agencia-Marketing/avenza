---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { langStaticPaths } from '../../../i18n/paths';
import { type Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  return langStaticPaths();
}

const lang = Astro.params.lang as Lang;
const base = `/${lang}`;

const isProd = import.meta.env.PROD;
const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === lang && (!isProd || !p.data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const dateFmt = new Intl.DateTimeFormat(lang, { year: 'numeric', month: 'long', day: 'numeric' });
const slugOf = (id: string) => id.split('/').pop()!;

const strings = {
  es: { tag: 'Blog', title: 'Aprende, organiza y crece', sub: 'Artículos claros y prácticos sobre impuestos, negocios, ahorro y finanzas personales.', empty: 'Pronto publicaremos nuevos artículos. Vuelve pronto.' },
  en: { tag: 'Blog', title: 'Learn, organize & grow', sub: 'Clear, practical articles on taxes, business, saving, and personal finance.', empty: 'New articles coming soon. Check back shortly.' },
}[lang];
---
<Base lang={lang} title={`${strings.title} | Avenza`} description={strings.sub}>
  <section class="hero-sub">
    <div class="container">
      <p class="section-tag" style="color:rgba(255,255,255,0.6)">{strings.tag}</p>
      <h1>{strings.title}</h1>
      <div class="divider-line"></div>
      <p>{strings.sub}</p>
    </div>
  </section>

  <section>
    <div class="container">
      {posts.length === 0 ? (
        <div class="blog-empty">{strings.empty}</div>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <a class="blog-card" href={`${base}/blog/${slugOf(post.id)}`}>
              {post.data.cover && <img class="cover" src={post.data.cover} alt="" loading="lazy" />}
              <div class="body">
                <span class="date">{dateFmt.format(post.data.pubDate)}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.map((tag) => (<span class="blog-tag">{tag}</span>))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
